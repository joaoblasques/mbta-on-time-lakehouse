# --- Python / uv ---
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
.coverage
htmlcov/

# --- Databricks ---
.databricks/
.databricks-login.json

