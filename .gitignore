# --- Secrets (NEVER commit — public repo) ---
.env
.env.*
!.env.example
*.pem
*.key
credentials
gcp-credentials*
*service-account*.json
application_default_credentials.json
databricks.token
*.tfvars
!*.tfvars.example

# --- Terraform ---
.terraform/
*.tfstate
*.tfstate.*
crash.log
.terraform.lock.hcl.bak
