# Copy to .env and fill in. .env is gitignored — NEVER commit real values.

# MBTA V3 API key — https://api-v3.mbta.com/ (free signup)
MBTA_API_KEY=

# AWS — prefer SSO (`aws configure sso`); these are only for non-SSO fallback.
AWS_REGION=us-east-1
# AWS_PROFILE=mbta-lakehouse

# Databricks (set after workspace exists)
# DATABRICKS_HOST=
# DATABRICKS_TOKEN=
