# Copy to .env and fill in. .env is gitignored — NEVER commit real values.

# MBTA V3 API key — https://api-v3.mbta.com/ (free signup)
MBTA_API_KEY=

# GCP — auth via `gcloud auth application-default login` (ADC); these name the resources.
GOOGLE_CLOUD_PROJECT=
GCP_REGION=us-east1
# PUBSUB_TOPIC=mbta-gtfs-rt
# GCS_BRONZE_BUCKET=

# Databricks (set after workspace exists)
# DATABRICKS_HOST=
# DATABRICKS_TOKEN=
